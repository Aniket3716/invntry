# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=inventory_db

# ── Backend ───────────────────────────────────────────────────────────────────
APP_ENV=development
# DATABASE_URL is auto-constructed from POSTGRES_* vars in docker-compose
# Override here only if connecting to an external DB:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Frontend ──────────────────────────────────────────────────────────────────
# In dev: the CRA proxy in package.json handles /api calls
# In production: set this to your public backend URL
REACT_APP_API_URL=http://localhost:8000
